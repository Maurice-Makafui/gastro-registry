# Copy this file to .env.local for local development.
# In production, set these in the Vercel dashboard — never commit .env.local.

# URL of the Render backend (no trailing slash)
# Local:      http://localhost:8000
# Production: https://gastro-referral-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

NEXT_PUBLIC_APP_NAME="Gastro Referral System"
NEXT_PUBLIC_APP_VERSION="2.1.0"

# Supabase (only needed if frontend calls Supabase directly)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
